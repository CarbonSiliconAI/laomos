{
  "name": "laomos",
  "version": "2.1.1",
  "description": "LaoMOS Desktop",
  "main": "electron/main.cjs",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:server": "tsc -p tsconfig.json",
    "dev:electron": "npm run build:server && env ELECTRON_RUN_AS_NODE= electron .",
    "dist": "npm run build:server && electron-builder --publish never",
    "dist:mac": "npm run build:server && electron-builder --mac --publish never",
    "dist:win": "npm run build:server && electron-builder --win --publish never",
    "dist:beta": "npm run build:server && electron-builder --publish always",
    "dist:stable": "npm run build:server && electron-builder --publish always"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "repository": "github:CarbonSiliconAI/aios",
  "type": "commonjs",
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.3",
    "adm-zip": "^0.5.16",
    "apache-arrow": "^14.0.2",
    "axios": "^1.13.5",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.9",
    "express": "^5.2.1",
    "fs-extra": "^11.3.3",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "imap-simple": "^5.1.0",
    "mailparser": "^3.9.3",
    "nodemailer": "^8.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "vectordb": "^0.21.2",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/imap-simple": "^4.2.10",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^10.0.0",
    "@types/yauzl": "^2.10.3",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.laomos.desktop",
    "productName": "LaoMOS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist{,/**/*}",
      "public{,/**/*}",
      "electron{,/**/*}",
      "package.json"
    ],
    "asarUnpack": [
      "dist{,/**/*}"
    ],
    "publish": [
      {
        "provider": "github"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "optionalDependencies": {
    "@lancedb/vectordb-darwin-arm64": "^0.21.2",
    "@lancedb/vectordb-win32-x64-msvc": "^0.21.2"
  }
}
